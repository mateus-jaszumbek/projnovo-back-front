FROM node:24-alpine AS build
WORKDIR /app

ARG VITE_API_URL=/api
ARG VITE_LEGAL_APP_NAME="Servicos App"
ARG VITE_LEGAL_APP_URL="http://localhost"
ARG VITE_LEGAL_CONTROLLER_NAME="Servicos App"
ARG VITE_LEGAL_CONTROLLER_DOCUMENT="Documento sob atualizacao"
ARG VITE_LEGAL_SUPPORT_EMAIL="contato@seudominio.com"
ARG VITE_LEGAL_PRIVACY_EMAIL="privacidade@seudominio.com"
ARG VITE_LEGAL_ADDRESS="Endereco comercial sob atualizacao"

ENV VITE_API_URL=$VITE_API_URL
ENV VITE_LEGAL_APP_NAME=$VITE_LEGAL_APP_NAME
ENV VITE_LEGAL_APP_URL=$VITE_LEGAL_APP_URL
ENV VITE_LEGAL_CONTROLLER_NAME=$VITE_LEGAL_CONTROLLER_NAME
ENV VITE_LEGAL_CONTROLLER_DOCUMENT=$VITE_LEGAL_CONTROLLER_DOCUMENT
ENV VITE_LEGAL_SUPPORT_EMAIL=$VITE_LEGAL_SUPPORT_EMAIL
ENV VITE_LEGAL_PRIVACY_EMAIL=$VITE_LEGAL_PRIVACY_EMAIL
ENV VITE_LEGAL_ADDRESS=$VITE_LEGAL_ADDRESS

COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build

FROM nginx:1.29-alpine AS runtime
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
